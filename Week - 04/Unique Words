Question: Given a sentence, count how many words satisfy both of the following conditions:
The length of the word is greater than 3.
Every character in the word is unique (no character is repeated).
Print the total count.

Text = input()
words = text.split()
count = 0
for word in words:
    if len(word) > 3:
        unique = True
        for i in range(len(word)):
            for j in range(i + 1, len(word)):
                if word[i] == word[j]:
                    unique = False
                    break
            if unique == False:
                break
        if unique:
            count += 1
print(count)
