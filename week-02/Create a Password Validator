password = input()
has_upper = False
has_lower = False
has_digit = False

for i in password:
  if i.isupper():
    has_upper = True
  elif i.islower():
    has_lower = True
  elif i.isdigit():
    has_digit = True
if len(password) >= 8 and has_upper and has_lower and has_digit:
    print("Valid Password")
else:
    print("Invalid Password")
